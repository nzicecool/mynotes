# ── .dockerignore ─────────────────────────────────────────────────────────────
# Excludes large/unnecessary directories from the Docker build context.
# Saves ~600MB of node_modules being sent to the Docker daemon on every build.
# Stage 1 of the Dockerfile runs "pnpm install" fresh inside the container.

# Dependencies (reinstalled inside Docker by pnpm install)
node_modules/
.pnpm-store/

# Build output (generated during Docker build)
dist/
client/dist/

# Development and test files
.manus-logs/
.webdev/
*.test.ts
*.spec.ts

# Environment secrets — NEVER bake into the image
# Note: deploy/.env is the only .env file used by docker compose
deploy/.env

# Version control
.git/
.gitignore

# Editor and OS artefacts
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Documentation (not needed at runtime)
README.md
CHANGELOG.md
docs/

# Test databases
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# TypeScript incremental build cache
*.tsbuildinfo

# Coverage and test output
coverage/
.nyc_output/
