# MyNotes — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ─── Database ────────────────────────────────────────────────────────────────
# MySQL/TiDB connection string
DATABASE_URL=mysql://user:password@localhost:3306/mynotes

# ─── Authentication ──────────────────────────────────────────────────────────
# Secret used to sign JWT session tokens (use a long random string, min 32 chars)
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# ─── Optional SMTP (for password reset emails) ───────────────────────────────
# If not set, reset links are printed to the server console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MyNotes <noreply@mynotes.local>

# ─── Manus Platform (auto-injected in hosted environments) ───────────────────
# Only set these for fully self-hosted deployments outside Manus.
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
